# --- Django ---
DEBUG=False
SECRET_KEY=change-me-in-production-very-long-random-string
ALLOWED_HOSTS=alleg.kg,www.alleg.kg,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://alleg.kg,https://www.alleg.kg
CSRF_TRUSTED_ORIGINS=https://alleg.kg,https://www.alleg.kg

# --- Postgres ---
POSTGRES_DB=alleg
POSTGRES_USER=alleg
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Superuser (создаётся entrypoint'ом при первом запуске) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@alleg.kg
DJANGO_SUPERUSER_PASSWORD=replace-me

